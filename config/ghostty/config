# Theme
# ghostty +list-themes
theme = Catppuccin Latte
# 眩しさを抑えるため背景を Latte crust 相当まで落とす。文字色は herdr 公式サイト実測値
background = #dce0e8
foreground = #44455d

# Font
# ghostty +list-themes
font-family = "Maple Mono NF"
font-family = "HackGen Console NF"
font-feature = -dlig
font-feature = -liga
font-feature = -calt
font-size = 13

font-style-bold = false
font-style-italic = false
font-style-bold-italic = false

# ライト背景は黒文字が細く見える (ダーク背景のグロー効果がない) ため、ステムを太らせる
# 太すぎる場合は font-thicken-strength = 0-255 で弱める (デフォルト 255)
font-thicken = true
# adjust-cell-width = 1
adjust-cell-height = 1

# herdr のペイン枠線など罫線文字 (box-drawing) を太くする
adjust-box-thickness = 115%

# background-opacity = 0.85
# background-blur-radius = 20

alpha-blending = linear

# macOS
macos-titlebar-style = transparent
macos-window-shadow = false

# Window
window-padding-x = 4
window-padding-y = 4
window-padding-balance = true
scrollbar = never

scrollback-limit = 5000000

palette-generate = false

# Shell
shell-integration-features = no-cursor

# Cursor
cursor-style = block
cursor-style-blink = false
cursor-invert-fg-bg = true
cursor-opacity = 0.8

# Other
mouse-hide-while-typing = true
resize-overlay = never

keybind = ctrl+left_bracket=text:\x1b

# ⌘+hjkl → unique escape sequences (tmux pane / Neovim window navigation)
# Kitty keyboard protocol: CSI <unicode_codepoint> ; <modifier+1> u (super=8, +1=9)
keybind = super+h=text:\x1b[104;9u
keybind = super+j=text:\x1b[106;9u
keybind = super+k=text:\x1b[107;9u
keybind = super+l=text:\x1b[108;9u
