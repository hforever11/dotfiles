[user]
	email = {{ .email }}
	name = {{ .name }}

[core]
	quotepath = false
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	features = catppuccin-frappe
	navigate = true
	line-numbers = true
	side-by-side = true

[merge]
	conflictStyle = zdiff3

[include]
	path = ~/.config/delta/themes/catppuccin.gitconfig
