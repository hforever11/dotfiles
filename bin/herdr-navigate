#!/bin/sh
# herdr の C-h/j/k/l 直接ペイン移動 (config.toml の type = "shell" バインドから呼ばれる)。
# tmux の is_vim 分岐 (vim-tmux-navigator) を socket API で再現する:
# vim ならキーを転送、それ以外は herdr のペインを移動。
# type = "shell" のゾンビリークは herdr 0.7.4 で修正済み (z-ai/herdr-zombie-leak.md)。
# herdr が動いていなければ set -e で黙って no-op になる。
#
# usage: herdr-navigate left|down|up|right

set -eu

# /bin/sh 経由の最小 PATH でも herdr を見つけられるよう nix profile を追加
PATH="/etc/profiles/per-user/$(id -un)/bin:/run/current-system/sw/bin:$PATH"

case "$1" in
  left)  key=ctrl+h ;;
  down)  key=ctrl+j ;;
  up)    key=ctrl+k ;;
  right) key=ctrl+l ;;
  *) echo "usage: herdr-navigate left|down|up|right" >&2; exit 1 ;;
esac

info=$(herdr pane process-info --current)

# tmux の vim_pat と同じ判定 (argv0 がパス付きでも一致)
if printf '%s' "$info" | grep -qE '"argv0":"([^"]*/)?g?(view|n?vim?x?)(diff)?"'; then
  pane_id=$(printf '%s' "$info" | grep -o '"pane_id":"[^"]*"' | head -1 | cut -d'"' -f4)
  exec herdr pane send-keys "$pane_id" "$key"
fi

exec herdr pane focus --direction "$1" --current
