{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -uo pipefail

# Brewfile hash: {{ include "Brewfile" | sha256sum }}
# mise config hash: {{ include "dot_config/mise/config.toml" | sha256sum }}

# Install Homebrew if not present
if ! command -v brew &>/dev/null; then
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Homebrew 6+ はサードパーティ tap を trust しないと formula をロードできない
if brew trust --help &>/dev/null; then
    grep -E '^tap "' "{{ .chezmoi.sourceDir }}/Brewfile" | cut -d'"' -f2 | while read -r tap; do
        brew trust "$tap" || echo "Warning: failed to trust tap: $tap"
    done
fi

# Install packages from Brewfile
echo "Installing packages from Brewfile..."
brew bundle --file="{{ .chezmoi.sourceDir }}/Brewfile" || echo "Warning: some Brewfile dependencies failed to install"

# Install runtimes managed by mise
if command -v mise &>/dev/null; then
    echo "Installing runtimes from mise config..."
    mise install -y || echo "Warning: some mise runtimes failed to install"
fi

# Install pokemon-colorscripts (no Homebrew formula available)
if ! command -v pokemon-colorscripts &>/dev/null; then
    echo "Installing pokemon-colorscripts..."
    tmp="$(mktemp -d)"
    git clone --depth=1 https://github.com/nuke-dash/pokemon-colorscripts-mac.git "$tmp"
    cd "$tmp" && sudo ./install.sh
    rm -rf "$tmp"
fi
{{ end -}}
