{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -uo pipefail

# Brewfile hash: {{ include "Brewfile" | sha256sum }}

# Install Homebrew if not present
if ! command -v brew &>/dev/null; then
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Install packages from Brewfile
echo "Installing packages from Brewfile..."
brew bundle --file="{{ .chezmoi.sourceDir }}/Brewfile" || echo "Warning: some Brewfile dependencies failed to install"

# Build bat theme cache
if command -v bat &>/dev/null; then
    echo "Building bat theme cache..."
    bat cache --build
fi

# Install pokemon-colorscripts (no Homebrew formula available)
if ! command -v pokemon-colorscripts &>/dev/null; then
    echo "Installing pokemon-colorscripts..."
    tmp="$(mktemp -d)"
    git clone --depth=1 https://github.com/nuke-dash/pokemon-colorscripts-mac.git "$tmp"
    cd "$tmp" && sudo ./install.sh
    rm -rf "$tmp"
fi
{{ end -}}
